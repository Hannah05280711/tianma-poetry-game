.container {
  width: 100%;
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #f5f5f5;
}

.navbar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12px 16px;
  background-color: #fff;
  border-bottom: 1px solid #eee;
  z-index: 100;
}

.navbar-title {
  font-size: 18px;
  font-weight: bold;
  color: #333;
}

.navbar-actions {
  display: flex;
  gap: 8px;
}

.navbar-btn {
  padding: 6px 12px;
  font-size: 14px;
  background-color: #f0f0f0;
  border: none;
  border-radius: 4px;
  color: #333;
  line-height: 1;
}

.navbar-btn:active {
  background-color: #e0e0e0;
}

web-view {
  flex: 1;
  width: 100%;
}

.share-menu {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 200;
  animation: slideUp 0.3s ease-out;
  display: flex;
  align-items: flex-end;
}

.share-content {
  width: 100%;
  background-color: #fff;
  border-radius: 16px 16px 0 0;
}

.share-item {
  padding: 16px;
  border-bottom: 1px solid #eee;
  text-align: center;
  font-size: 16px;
  color: #333;
}

.share-item:last-child {
  border-bottom: none;
}

.share-item.cancel {
  color: #999;
  font-weight: 500;
}

.share-item:active {
  background-color: #f5f5f5;
}

@keyframes slideUp {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
}
